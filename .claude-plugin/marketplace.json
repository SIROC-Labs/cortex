{
  "name": "siroc-cortex",
  "owner": {
    "name": "SIROC Team"
  },
  "metadata": {
    "description": "SIROC Cortex plugin marketplace",
    "version": "1.0.0",
    "pluginRoot": "./plugins"
  },
  "allowCrossMarketplaceDependenciesOn": [
    "claude-plugins-official"
  ],
  "plugins": [
    {
      "name": "cortex-workflow",
      "source": "./plugins/cortex-workflow",
      "description": "End-to-end development workflow: from ticket to shipped PR with automated task tracking, git management, and team communication",
      "version": "1.5.0",
      "dependencies": [
        {
          "name": "feature-dev",
          "marketplace": "claude-plugins-official"
        },
        {
          "name": "superpowers",
          "marketplace": "claude-plugins-official"
        }
      ]
    },
    {
      "name": "dev-toolkit",
      "source": "./plugins/dev-toolkit",
      "description": "Independent, reusable development utilities",
      "version": "0.3.0"
    }
  ]
}
